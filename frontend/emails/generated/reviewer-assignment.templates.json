[
  {
    "template_key": "reviewer_invitation_standard",
    "display_name": "审稿邀请信（React Email）",
    "description": "由 React Email 生成，可用于审稿邀请。",
    "scene": "reviewer_assignment",
    "event_type": "invitation",
    "subject_template": "Invitation to Review - {{ journal_title }}",
    "body_html_template": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\"><html dir=\"ltr\" lang=\"en\"><head><meta content=\"text/html; charset=UTF-8\" http-equiv=\"Content-Type\"/><meta name=\"x-apple-disable-message-reformatting\"/></head><body style=\"background-color:#f3f6fb;margin:0\"><table border=\"0\" width=\"100%\" cellPadding=\"0\" cellSpacing=\"0\" role=\"presentation\" align=\"center\"><tbody><tr><td style=\"background-color:#f3f6fb;color:#0f172a;font-family:Arial, &quot;Helvetica Neue&quot;, Helvetica, sans-serif;margin:0;padding:24px 0\"><table align=\"center\" width=\"100%\" border=\"0\" cellPadding=\"0\" cellSpacing=\"0\" role=\"presentation\" style=\"max-width:640px;background-color:#ffffff;border:1px solid #dbe3f1;border-radius:12px;margin:0 auto;padding:28px 24px\"><tbody><tr style=\"width:100%\"><td><p style=\"font-size:12px;line-height:24px;color:#2563eb;font-weight:700;letter-spacing:0.08em;margin:0;text-transform:uppercase;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0\">Peer Review Invitation</p><h1 style=\"color:#0b1a34;font-size:22px;font-weight:700;line-height:1.35;margin:10px 0 14px\">Invitation to Review</h1><p style=\"font-size:15px;line-height:1.7;color:#334155;margin:10px 0;margin-top:10px;margin-right:0;margin-bottom:10px;margin-left:0\">Dear {{ reviewer_name }},</p><p style=\"font-size:15px;line-height:1.7;color:#334155;margin:10px 0;margin-top:10px;margin-right:0;margin-bottom:10px;margin-left:0\">You are invited to review the manuscript <strong>{{ manuscript_title }}</strong> for <strong>{{ journal_title }}</strong>.</p><table align=\"center\" width=\"100%\" border=\"0\" cellPadding=\"0\" cellSpacing=\"0\" role=\"presentation\" style=\"background-color:#f8fbff;border:1px solid #e2ebfa;border-radius:10px;margin-top:16px;padding:14px 16px\"><tbody><tr><td><p style=\"font-size:12px;line-height:24px;color:#64748b;letter-spacing:0.06em;margin:0;text-transform:uppercase;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0\">Manuscript ID</p><p style=\"font-size:14px;line-height:1.5;color:#0f172a;font-weight:600;margin:4px 0 0;margin-top:4px;margin-right:0;margin-bottom:0;margin-left:0\">{{ manuscript_id }}</p><p style=\"font-size:12px;line-height:24px;color:#64748b;letter-spacing:0.06em;margin:0;text-transform:uppercase;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0\">Requested Due Date</p><p style=\"font-size:14px;line-height:1.5;color:#0f172a;font-weight:600;margin:4px 0 0;margin-top:4px;margin-right:0;margin-bottom:0;margin-left:0\">{{ due_date }}</p></td></tr></tbody></table><a href=\"{{ review_url }}\" style=\"line-height:1;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:#2563eb;border-radius:9px;box-sizing:border-box;color:#ffffff;font-size:14px;font-weight:700;margin-top:18px;padding:12px 18px;padding-top:12px;padding-right:18px;padding-bottom:12px;padding-left:18px\" target=\"_blank\"><span><!--[if mso]><i style=\"mso-font-width:450%;mso-text-raise:18\" hidden>&#8202;&#8202;</i><![endif]--></span><span style=\"max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:9px\">Open Invitation</span><span><!--[if mso]><i style=\"mso-font-width:450%\" hidden>&#8202;&#8202;&#8203;</i><![endif]--></span></a><hr style=\"width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e2e8f0;margin:20px 0 14px\"/><p style=\"font-size:12px;line-height:1.6;color:#94a3b8;margin:12px 0 0;margin-top:12px;margin-right:0;margin-bottom:0;margin-left:0\">If the button cannot be clicked, copy and open this link:<br/>{{ review_url }}</p></td></tr></tbody></table></td></tr></tbody></table></body></html>",
    "body_text_template": "Peer Review Invitation\n\n\nINVITATION TO REVIEW\n\nDear {{ reviewer_name }},\n\nYou are invited to review the manuscript {{ manuscript_title }} for {{ journal_title }}.\n\nManuscript ID\n\n{{ manuscript_id }}\n\nRequested Due Date\n\n{{ due_date }}\n\nOpen Invitation {{ review_url }}\n\n----------------------------------------\n\nIf the button cannot be clicked, copy and open this link:\n{{ review_url }}",
    "is_active": true
  },
  {
    "template_key": "reviewer_reminder_polite",
